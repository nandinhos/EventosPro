APP_NAME=eventosprofssdevcombr
APP_ENV=production
APP_KEY=base64:xzcPrNOO4CwMoGvyVE//KtZIaZ1cOClMw8rJKDOYekc=
APP_DEBUG=false
APP_URL=https://eventospro.fssdev.com.br
LOG_CHANNEL=stderr
APP_IMAGE=packgrid.mwguerra.com/primeforge/panel:latest
TRUSTED_PROXIES=*

# Database
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=eventosprofssdevcombr_db
DB_USERNAME=eventosprofssdevcombr_user
DB_PASSWORD=280fb0db55986016e81b30560db2d374

# Redis
REDIS_HOST=host.docker.internal
REDIS_PASSWORD=e1b51ceb61b919da83925fd30e6216bd3ef8cc738ee3f177fd2e7c765adf8189
REDIS_PREFIX=eventosprofssdevcombr_

# Cache, Queue, Session - Use file se Redis não estiver disponível no cPanel
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Laravel Defaults
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=${APP_NAME}

# AWS (não configurado)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME=${APP_NAME}
WWWUSER=1000
WWWGROUP=1000
