# EventosPro - Staging Environment Configuration
# VPS Optimized: Environment "quase produção" para testes

# ============================================
# Application
# ============================================
APP_NAME="EventosPro Staging"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=http://staging.seu-dominio.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ============================================
# Logging (mais verbose que production)
# ============================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ============================================
# Database (MySQL via Docker)
# ============================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=eventospro_staging
DB_USERNAME=eventospro_staging_user
DB_PASSWORD=CHANGE_THIS_STAGING_PASSWORD

# ============================================
# Redis (Cache, Sessions, Queue)
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# Cache (Using Redis for performance)
# ============================================
CACHE_STORE=redis
CACHE_PREFIX=eventospro_staging_cache

# ============================================
# Sessions (Using Redis for performance)
# ============================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# Queue (Using Redis for reliability)
# ============================================
QUEUE_CONNECTION=redis

# ============================================
# Broadcasting
# ============================================
BROADCAST_CONNECTION=log

# ============================================
# Filesystem
# ============================================
FILESYSTEM_DISK=local

# ============================================
# Mail (Use Mailtrap or test SMTP)
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="staging@eventospro.local"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS (Optional - for S3 storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# Vite
# ============================================
VITE_APP_NAME="${APP_NAME}"

# ============================================
# Docker Port Forwarding (Optional)
# ============================================
FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380

# ============================================
# Staging-Specific Settings
# ============================================
# Debugbar: Pode ser true em staging para debug (mas false em production!)
DEBUGBAR_ENABLED=false

# Telescope: Útil para monitoramento em staging
TELESCOPE_ENABLED=false

# ============================================
# Security (menos restritivo que production)
# ============================================
# Permitir acesso de IPs específicos se necessário
# ALLOWED_IPS=192.168.1.100,10.0.0.5

# ============================================
# Performance (menos agressivo que production)
# ============================================
# Session lifetime maior para testes prolongados
SESSION_LIFETIME=240

# ============================================
# Third-party Services (Use sandbox/test modes)
# ============================================
# Pagamento: Usar modo sandbox
# PAYMENT_GATEWAY_MODE=sandbox
# PAYMENT_GATEWAY_KEY=test_key_xxxxx

# Analytics: Desabilitar ou usar propriedade de teste
# GOOGLE_ANALYTICS_ID=

# Sentry (error tracking): Usar projeto staging separado
# SENTRY_LARAVEL_DSN=https://xxx@sentry.io/staging

# ============================================
# Notes for Staging Environment
# ============================================
# - Use dados de TESTE, não dados reais de produção
# - Pode usar cópia anonimizada do banco de produção
# - Mailtrap captura todos os emails (nada é enviado de verdade)
# - Modo staging permite mais logs/debug que production
# - Sempre teste aqui ANTES de ir para production
