# EventosPro - Production Environment Configuration
# VPS Optimized: Redis enabled for cache/sessions/queue

# ============================================
# Application
# ============================================
APP_NAME="EventosPro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-domain.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================
# Database (MySQL via Docker)
# ============================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=eventospro_production
DB_USERNAME=eventospro_user
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# ============================================
# Redis (Cache, Sessions, Queue)
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# Cache (Using Redis for performance)
# ============================================
CACHE_STORE=redis
CACHE_PREFIX=eventospro_cache

# ============================================
# Sessions (Using Redis for performance)
# ============================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# Queue (Using Redis for reliability)
# ============================================
QUEUE_CONNECTION=redis

# ============================================
# Broadcasting
# ============================================
BROADCAST_CONNECTION=log

# ============================================
# Filesystem
# ============================================
FILESYSTEM_DISK=local

# ============================================
# Mail (Configure with your SMTP provider)
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS (Optional - for S3 storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# Vite
# ============================================
VITE_APP_NAME="${APP_NAME}"

# ============================================
# Docker Port Forwarding (Optional)
# ============================================
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379

# ============================================
# Performance Optimizations
# ============================================
# Disable unnecessary features
DEBUGBAR_ENABLED=false

# ============================================
# Security
# ============================================
# Add your domain for CORS if needed
# SANCTUM_STATEFUL_DOMAINS=your-domain.com
