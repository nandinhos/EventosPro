# EventosPro - VPS Production Environment Configuration
# =========================================================
# Este arquivo contém configurações otimizadas para VPS
# com portas customizadas para evitar conflitos com outras aplicações
#
# IMPORTANTE: Copie para .env e ajuste as portas conforme necessário
# =========================================================

APP_NAME="EventosPro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging Configuration (Production)
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database Configuration (VPS - Instalação Direta ou Docker)
# Para Docker: use DB_HOST=mysql
# Para instalação direta: use DB_HOST=127.0.0.1
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=eventospro_production
DB_USERNAME=eventospro_user
DB_PASSWORD=SENHA_FORTE_AQUI

# Session Configuration (Production)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.seu-dominio.com
SESSION_SECURE_COOKIE=true

# Broadcasting & Cache
BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Cache Configuration (Production with Redis)
CACHE_STORE=redis
CACHE_PREFIX=eventospro_cache

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Production)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.seu-provedor.com
MAIL_PORT=587
MAIL_USERNAME=contato@seu-dominio.com
MAIL_PASSWORD=senha_email_aqui
MAIL_FROM_ADDRESS="contato@seu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (se usar S3 para storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =========================================================
# Docker Sail / Docker Compose Configuration
# =========================================================
# IMPORTANTE: Ajuste estas portas para evitar conflitos!
# =========================================================

# Docker User (ajuste para seu UID/GID)
WWWUSER=1000
WWWGROUP=1000

# =========================================================
# CONFIGURAÇÃO DE PORTAS (VPS - EVITAR CONFLITOS)
# =========================================================
# Cada aplicação na VPS deve ter portas únicas
# Exemplo: EventosPro usa 8001, OutraApp usa 8002, etc.
# =========================================================

# Porta da Aplicação Laravel (Nginx)
# Acesso: http://IP-VPS:8001
FORWARD_APP_PORT=8001

# Porta do MySQL
# Acesso externo (opcional): mysql -h IP-VPS -P 33061 -u user -p
FORWARD_DB_PORT=33061

# Porta do Redis
# Acesso externo (opcional): redis-cli -h IP-VPS -p 63791
FORWARD_REDIS_PORT=63791

# Porta do PHPMyAdmin (opcional - remover em produção por segurança)
# Acesso: http://IP-VPS:8801
FORWARD_PHPMYADMIN_PORT=8801

# Porta do Mailpit (local email testing - remover em produção)
# FORWARD_MAILPIT_PORT=1025
# FORWARD_MAILPIT_DASHBOARD_PORT=8025

# =========================================================
# Performance & Optimization (Production)
# =========================================================

# Opcache (Production)
OPCACHE_ENABLE=1
OPCACHE_REVALIDATE_FREQ=60

# Queue Workers
QUEUE_WORKERS=3

# Trusted Proxies (se usar Load Balancer/Cloudflare)
TRUSTED_PROXIES=*

# =========================================================
# Security Headers
# =========================================================
# Configurar no Nginx também

# =========================================================
# Backup Configuration
# =========================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# =========================================================
# Monitoring & Error Tracking (Opcional)
# =========================================================
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2

# =========================================================
# NOTAS IMPORTANTES:
# =========================================================
# 1. Sempre use HTTPS em produção (configure SSL/TLS no Nginx)
# 2. Gere APP_KEY forte: php artisan key:generate
# 3. Nunca commite este arquivo com senhas reais!
# 4. Use senhas fortes para DB_PASSWORD
# 5. Configure firewall para as portas usadas
# 6. Considere usar .env.encrypted para secrets
# 7. Configure backups automáticos (cron)
# =========================================================

# Para gerar APP_KEY execute:
# docker-compose run --rm laravel.test php artisan key:generate
# ou (se instalação direta):
# php artisan key:generate
