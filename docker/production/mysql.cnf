# EventosPro - MySQL Configuration for VPS Production
# Optimized for: 4GB RAM VPS (allocating ~1-1.5GB to MySQL)

[mysqld]

# General settings
max_connections = 100
max_allowed_packet = 64M
thread_cache_size = 8
table_open_cache = 2000
table_definition_cache = 1400

# InnoDB settings (optimized for 1.5GB allocation)
innodb_buffer_pool_size = 512M
innodb_log_file_size = 128M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1

# Query cache (disabled in MySQL 8.0+, but keeping for reference)
# query_cache_type = 0
# query_cache_size = 0

# Temp tables
tmp_table_size = 32M
max_heap_table_size = 32M

# Slow query log (for optimization)
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2

# Binary logging (for backups and replication)
log_bin = /var/lib/mysql/mysql-bin
binlog_expire_logs_seconds = 604800
max_binlog_size = 100M

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Performance schema (can be disabled to save RAM if not needed)
performance_schema = OFF
